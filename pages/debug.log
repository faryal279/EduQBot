estionText}</div> </div> </div> `; }); // Save to database fetch('save_question.php', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ input_text: input, questions: data.response }) }) .catch(err => console.error('Failed to save history:', err)); downloadBtn.disabled = false; downloadBtn.onclick = () => { const blob = new Blob([JSON.stringify(questions, null, 2)], { type: \"application/json\" }); const link = document.createElement('a'); link.href = URL.createObjectURL(blob); link.download = \"questions.json\"; link.click(); }; } else { outputBox.innerHTML = `<div class=\"question-text\">${data.response}</div>`; } } catch (e) { outputBox.innerHTML = `<div class=\"question-text\">${data.response}</div>`; } } else { outputBox.innerHTML = '<p class=\"placeholder-text\">No questions generated.</p>'; } }) .catch(err => { loading.style.display = 'none'; error.textContent = 'Error contacting server.'; error.style.display = 'block'; }); }); </script> <script src=\"../js/header.js\"></script> </body> </html>"}
